# Environment Variables Example
# Copy this file to .env and update values

# App Settings
EXPO_PUBLIC_APP_NAME=Notesie
EXPO_PUBLIC_APP_VERSION=1.0.0

# Note: All notes are stored locally on device
# No API calls or external services are used in the base version

# For future integrations:
# FIREBASE_API_KEY=your_key_here
# FIREBASE_AUTH_DOMAIN=your_domain_here
# ICLOUD_CONTAINER_ID=iCloud.com.yourcompany.notesie
